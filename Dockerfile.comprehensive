# Test 2: Memory Read Operations
log_section "Test 2: Memory Read - Retrieval Tests"

node <<'NODEScript'
const fs = require('fs');
const path = require('path');

const MEMORY_FILE = path.join('/root/.opencode/memory', 'MEMORY.md');
const content = fs.readFileSync(MEMORY_FILE, 'utf8');

console.log('📖 Reading memory file...\n');

