# Test 3: BM25 Search - Multiple Queries
log_section "Test 3: BM25 Keyword Search - Real Queries"

node <<'NODEScript'
const fs = require('fs');
const path = require('path');

const MEMORY_DIR = '/root/.opencode/memory';
const files = fs.readdirSync(MEMORY_DIR).filter(f => f.endsWith('.md'));

console.log('🔍 Running multiple search queries...\n');

const queries = [
  'typescript type safety',
  'vector search performance',
  'docker platform compatibility',
  'hybrid search algorithm',
  'bug fix solution'
];

queries.forEach(query => {
  console.log(`\n  Query: "${query}"`);
  
  const queryWords = query.toLowerCase().split(/\s+/);
  const results = [];

  files.forEach(file => {
    const content = fs.readFileSync(path.join(MEMORY_DIR, file), 'utf8').toLowerCase();
    let score = 0;
    
    queryWords.forEach(word => {
      const matches = (content.match(new RegExp(word, 'g')) || []).length;
      score += matches;
    });

    if (score > 0) {
      results.push({ file, score });
    }
  });

  results.sort((a, b) => b.score - a.score);

  if (results.length > 0) {
    console.log(`  Results: ${results.length} files`);
    results.slice(0, 3).forEach((r, i) => {
      console.log(`    ${i + 1}. ${r.file} (score: ${r.score})`);
    });
  } else {
    console.log('  No results found');
  }
});

console.log('\n✅ BM25 search tests completed\n');
NODESCRIPT

# Test 4: Configuration Operations
