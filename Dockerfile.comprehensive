# Dockerfile for Complete OpenCode Memory Plugin Testing
# Tests all memory operations with real-world scenarios

FROM node:20

ENV NODE_ENV=production
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /usr/src/app

# Install build tools
RUN apt-get update && apt-get install -y \
    python3 make g++ curl git bash \
    && rm -rf /var/lib/apt/lists/*

# Copy and install plugin with correct platform binaries
COPY opencode-memory-plugin/package*.json ./opencode-memory-plugin/
WORKDIR /usr/src/app/opencode-memory-plugin
RUN npm install --production=false --ignore-scripts
COPY opencode-memory-plugin /usr/src/app/opencode-memory-plugin/
RUN npm rebuild
RUN npm install -g .

# Verify installation
RUN echo "=== Plugin Installation ===" && \
    ls -la ~/.opencode/memory/ && \
    echo "" && \
    echo "=== Native Modules ===" && \
    npm list sharp onnxruntime-node | grep -E "(sharp|onnxruntime)" && \
    echo "" && \
    echo "=== Memory Config ===" && \
    cat ~/.opencode/memory/memory-config.json | head -20

WORKDIR /usr/src/app

# Create comprehensive test script
COPY <<'EOF' /usr/src/app/run-comprehensive-tests.sh
