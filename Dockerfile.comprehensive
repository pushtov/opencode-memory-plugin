const fs = require('fs');
const path = require('path');

const CONFIG_PATH = '/root/.opencode/memory/memory-config.json';
const config = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));

console.log('⚙️  Testing configuration system...\n');

console.log('Current configuration:');
console.log(`  Version: ${config.version}`);
console.log(`  Search mode: ${config.search.mode}`);
console.log(`  Embedding enabled: ${config.embedding.enabled}`);
console.log(`  Model: ${config.embedding.model}`);
console.log(`  Fallback mode: ${config.embedding.fallbackMode}`);
console.log(`  Available models: ${Object.keys(config.models.available).length}`);

console.log('\n🔄 Testing mode switching...\n');

const modes = ['hybrid', 'vector', 'bm25', 'hash'];
const originalMode = config.search.mode;

modes.forEach(mode => {
  config.search.mode = mode;
  console.log(`  ✓ Switched to ${mode} mode`);
});

// Restore original
config.search.mode = originalMode;
fs.writeFileSync(CONFIG_PATH, JSON.stringify(config, null, 2));
console.log(`\n  ✓ Restored to ${originalMode} mode`);

console.log('\n✅ Configuration tests completed\n');
NODESCRIPT

# Test 5: Daily Log Operations
log_section "Test 5: Daily Log - Multi-Day Scenarios"

node <<'NODEScript'
const fs = require('fs');
const path = require('path');

const DAILY_DIR = '/root/.opencode/memory/daily';

console.log('📅 Testing daily log operations...\n');

// Create multiple daily logs
const dates = [
  new Date(Date.now() - 86400000 * 2).toISOString().split('T')[0], // 2 days ago
  new Date(Date.now() - 86400000).toISOString().split('T')[0],     // 1 day ago
  new Date().toISOString().split('T')[0]                           // today
];

console.log('Creating/verifying daily logs for:');
dates.forEach(date => {
  const dailyFile = path.join(DAILY_DIR, `${date}.md`);
  
  if (!fs.existsSync(dailyFile)) {
    const content = `# Daily Log - ${date}\n\n## Session Start\n\nStarted: ${new Date().toISOString()}\n\n## Activities\n\n- Testing plugin functionality\n- Running comprehensive tests\n\n## Notes\n\nTest day ${date}\n`;
    fs.writeFileSync(dailyFile, content);
    console.log(`  ✓ Created: ${date}.md`);
  } else {
    console.log(`  ⊙ Exists: ${date}.md`);
  }
});

const dailyFiles = fs.readdirSync(DAILY_DIR).filter(f => f.endsWith('.md'));
console.log(`\n  Total daily logs: ${dailyFiles.length}`);

console.log('\n✅ Daily log operations completed\n');
