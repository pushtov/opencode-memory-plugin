log_section() { echo -e "\n${BLUE}========================================${NC}"; echo -e "${BLUE}$1${NC}"; echo -e "${BLUE}========================================${NC}\n"; }

log_section "OpenCode Memory Plugin - Comprehensive Real-World Tests"

echo "Test Date: $(date)"
echo "Test Environment: Docker $(cat /etc/os-release | grep PRETTY_NAME | cut -d'"' -f2)"
echo "Node Version: $(node --version)"
