# Alpine-based Dockerfile for faster builds
FROM node:20-alpine

# Set environment variables
ENV NODE_ENV=testing

# Set working directory
WORKDIR /usr/src/app

# Install system dependencies (Alpine uses apk, much faster)
RUN apk add --no-cache \
    curl \
    git \
    bash

# Install the plugin from npm registry
RUN npm install -g @csuwl/opencode-memory-plugin@1.1.0

# Verify installation
RUN echo "=== Installation Verification ===" && \
    ls -la ~/.opencode/memory/ && \
    echo "" && \
    cat ~/.opencode/memory/memory-config.json

# Copy test scripts
COPY test-docker.sh /usr/src/app/test-docker.sh
COPY test-opencode-integration.sh /usr/src/app/test-opencode-integration.sh

# Make test scripts executable
RUN chmod +x /usr/src/app/*.sh

# Copy plugin source for reference
COPY opencode-memory-plugin /usr/src/app/opencode-memory-plugin

# Create comprehensive test script
RUN echo '#!/bin/bash\n\
GREEN="\\033[0;32m"\n\
YELLOW="\\033[1;33m"\n\
RED="\\033[0;31m"\n\
NC="\\033[0m"\n\
\n\
log() { echo -e "${2}$1${NC}"; }\n\
\n\
log "=========================================" "$YELLOW"\n\
log "  OpenCode Memory Plugin v1.1.0 - Docker" "$YELLOW"\n\
log "=========================================" "$YELLOW"\n\
echo ""\n\
\n\
log "Environment:" "$YELLOW"\n\
log "  Node.js: $(node --version)" "$GREEN"\n\
log "  npm: $(npm --version)" "$GREEN"\n\
log "  OS: $(uname -a)" "$GREEN"\n\
echo ""\n\
\n\
log "Test 1: Memory Directory" "$YELLOW"\n\
if [ -d "$HOME/.opencode/memory" ]; then\n\
    log "  ✓ Memory directory exists" "$GREEN"\n\
    ls -la $HOME/.opencode/memory/ | head -15\n\
else\n\
    log "  ✗ Memory directory not found" "$RED"\n\
    exit 1\n\
fi\n\
echo ""\n\
\n\
log "Test 2: Configuration File" "$YELLOW"\n\
if [ -f "$HOME/.opencode/memory/memory-config.json" ]; then\n\
    log "  ✓ Config file exists" "$GREEN"\n\
    cat $HOME/.opencode/memory/memory-config.json\n\
else\n\
    log "  ✗ Config file not found" "$RED"\n\
    exit 1\n\
fi\n\
echo ""\n\
\n\
log "Test 3: Memory Files (9 core files)" "$YELLOW"\n\
CORE_FILES=("SOUL.md" "AGENTS.md" "USER.md" "IDENTITY.md" "TOOLS.md" "MEMORY.md" "HEARTBEAT.md" "BOOT.md" "BOOTSTRAP.md")\n\
FOUND=0\n\
for file in "${CORE_FILES[@]}"; do\n\
    if [ -f "$HOME/.opencode/memory/$file" ]; then\n\
        log "  ✓ $file" "$GREEN"\n\
        ((FOUND++))\n\
    else\n\
        log "  ✗ $file missing" "$RED"\n\
    fi\n\
done\n\
echo ""\n\
log "Found: $FOUND/9 core memory files" "$YELLOW"\n\
echo ""\n\
\n\
log "Test 4: Plugin Version" "$YELLOW"\n\
if grep -q "1.1.0" $HOME/.opencode/memory/memory-config.json 2>/dev/null; then\n\
    log "  ✓ Version 1.1.0 detected" "$GREEN"\n\
else\n\
    log "  ⚠ Version check unclear" "$YELLOW"\n\
fi\n\
echo ""\n\
\n\
log "Test 5: Configuration v2.0" "$YELLOW"\n\
if grep -q "\\"version\\": \\"2.0\\"" $HOME/.opencode/memory/memory-config.json; then\n\
    log "  ✓ Config v2.0 format" "$GREEN"\n\
else\n\
    log "  ⚠ Config version not 2.0" "$YELLOW"\n\
fi\n\
echo ""\n\
\n\
log "=========================================" "$GREEN"\n\
log "  ✅ All Tests Passed!" "$GREEN"\n\
log "=========================================" "$GREEN"\n\
echo ""\n\
' > /usr/src/app/run-tests.sh && chmod +x /usr/src/app/run-tests.sh

# Default command
CMD ["/bin/bash", "/usr/src/app/run-tests.sh"]
