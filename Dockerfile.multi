# Multi-stage Dockerfile for faster builds with caching
FROM node:20-alpine AS builder

# Install build tools (separate layer for caching)
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    sqlite

# Set working directory
WORKDIR /build

# Copy package files first (for better caching)
COPY opencode-memory-plugin/package*.json ./opencode-memory-plugin/

# Install dependencies (will be cached if package.json unchanged)
RUN cd opencode-memory-plugin && \
    npm ci --timeout=180000

# Copy rest of plugin source
COPY opencode-memory-plugin /build/opencode-memory-plugin

# Final stage
FROM node:20-alpine

# Set environment variables
ENV NODE_ENV=testing

# Install runtime dependencies only
RUN apk add --no-cache \
    bash \
    sqlite

# Set working directory
WORKDIR /usr/src/app

# Copy built plugin from builder
COPY --from=builder /build/opencode-memory-plugin /usr/src/app/opencode-memory-plugin

# Install plugin globally
RUN cd /usr/src/app/opencode-memory-plugin && \
    npm install -g . && \
    npm cache clean --force

# Verify installation
RUN echo "Verifying installation..." && \
    ls -la ~/.opencode/memory/ && \
    echo "" && \
    cat ~/.opencode/memory/memory-config.json

# Copy test scripts
COPY test-docker.sh /usr/src/app/
COPY test-opencode-integration.sh /usr/src/app/

# Make scripts executable
RUN chmod +x /usr/src/app/*.sh

# Create test script
RUN echo '#!/bin/bash\n\
echo "========================================="\n\
echo "  OpenCode Memory Plugin v1.1.0 - Docker"\n\
echo "========================================="\n\
echo ""\n\
echo "Environment:"\n\
echo "  Node.js: $(node --version)"\n\
echo "  npm: $(npm --version)"\n\
echo ""\n\
echo "Test 1: Memory Directory"\n\
if [ -d "$HOME/.opencode/memory" ]; then\n\
    echo "  ✓ Memory directory exists"\n\
    ls -la $HOME/.opencode/memory/\n\
else\n\
    echo "  ✗ FAILED: Memory directory not found"\n\
    exit 1\n\
fi\n\
echo ""\n\
echo "Test 2: Configuration File"\n\
if [ -f "$HOME/.opencode/memory/memory-config.json" ]; then\n\
    echo "  ✓ Config file exists"\n\
    cat $HOME/.opencode/memory/memory-config.json\n\
else\n\
    echo "  ✗ FAILED: Config file not found"\n\
    exit 1\n\
fi\n\
echo ""\n\
echo "Test 3: Core Memory Files"\n\
CORE_FILES=("SOUL.md" "AGENTS.md" "USER.md" "IDENTITY.md" "TOOLS.md" "MEMORY.md" "HEARTBEAT.md" "BOOT.md" "BOOTSTRAP.md")\n\
FOUND=0\n\
for file in "${CORE_FILES[@]}"; do\n\
    if [ -f "$HOME/.opencode/memory/$file" ]; then\n\
        echo "  ✓ $file"\n\
        FOUND=$((FOUND + 1))\n\
    fi\n\
done\n\
echo "  Found: $FOUND/9 files"\n\
if [ "$FOUND" -ne 9 ]; then\n\
    echo "  ✗ FAILED: Not all files present"\n\
    exit 1\n\
fi\n\
echo ""\n\
echo "========================================="\n\
echo "  ✅ ALL TESTS PASSED!"\n\
echo "========================================="\n\
' > /usr/src/app/run-tests.sh && chmod +x /usr/src/app/run-tests.sh

# Default command
CMD ["/bin/bash", "/usr/src/app/run-tests.sh"]
