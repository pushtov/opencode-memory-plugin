# Test Dockerfile for Vector Search Implementation
# This tests the real vector search with embedding model loading

FROM node:20-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files
COPY opencode-memory-plugin/package*.json ./

# Install dependencies
RUN npm install

# Copy source files
COPY opencode-memory-plugin/ ./

# Create test script
RUN cat > test-vector-search.mjs << 'EOF'
import { getVectorStore } from './lib/vector-store.js';
import fs from 'fs';
import path from 'path';

const HOME = process.env.HOME || '/root';
const MEMORY_DIR = path.join(HOME, '.opencode', 'memory');

console.log('========================================');
console.log('Vector Search Implementation Test');
console.log('========================================\n');

// Test 1: Initialize Vector Store
console.log('Test 1: Initialize Vector Store');
console.log('--------------------------------');

try {
  const vs = getVectorStore();
  
  // Create memory directory and test content
  if (!fs.existsSync(MEMORY_DIR)) {
    fs.mkdirSync(MEMORY_DIR, { recursive: true });
  }
  
  // Create test memory file
  const testMemory = `# Memory Test File

## Preference Entry
**Date**: 2024-01-01
**Type**: preference

User prefers TypeScript for all new projects. They like strict type checking and explicit interfaces.

---

## Decision Entry
**Date**: 2024-01-02
**Type**: decision

Decided to use SQLite for local storage due to simplicity and zero-config requirement.

---

## Learning Entry
**Date**: 2024-01-03
**Type**: note

Learned that embedding models work best with chunked text. The all-MiniLM-L6-v2 model provides good balance between speed and quality.

---

## Pattern Entry
**Date**: 2024-01-04
**Type**: pattern

When implementing vector search, always normalize embeddings for cosine similarity. Use mean pooling for sentence embeddings.
`;
  
  fs.writeFileSync(path.join(MEMORY_DIR, 'MEMORY.md'), testMemory);
  console.log('✓ Created test memory file');
  
  const initResult = await vs.initialize();
  
  if (initResult.success) {
    console.log('✓ Vector store initialized');
    console.log(`  Model: ${initResult.model}`);
    console.log(`  Dimensions: ${initResult.dimensions}`);
  } else {
    console.log('✗ Failed to initialize:', initResult.error);
    console.log('  Falling back to keyword search...');
  }
} catch (e) {
  console.log('✗ Error:', e.message);
}

// Test 2: Index Documents
console.log('\nTest 2: Index Documents');
console.log('------------------------');

try {
  const vs = getVectorStore();
  
  const content = fs.readFileSync(path.join(MEMORY_DIR, 'MEMORY.md'), 'utf-8');
  const result = await vs.indexDocument(content, 'MEMORY.md', { clearExisting: true });
  
  console.log(`✓ Indexed ${result.indexed} chunks from ${result.source}`);
  
  const status = vs.getStatus();
  console.log(`  Total chunks: ${status.totalChunks}`);
  console.log(`  Last indexed: ${status.lastIndexed}`);
} catch (e) {
  console.log('✗ Error:', e.message);
}

// Test 3: Semantic Search
console.log('\nTest 3: Semantic Search');
console.log('------------------------');

try {
  const vs = getVectorStore();
  
  // Test queries that should match semantically
  const queries = [
    'What programming language does the user like?',
    'database storage choice',
    'how to implement vector embeddings',
    'machine learning models'
  ];
  
  for (const query of queries) {
    console.log(`\nQuery: "${query}"`);
    const results = await vs.search(query, { limit: 3, threshold: 0.2 });
    
    if (results.length > 0) {
      console.log(`  Found ${results.length} results:`);
      for (const r of results) {
        console.log(`  - [${r.source}] Score: ${r.score.toFixed(3)}`);
        console.log(`    "${r.content.substring(0, 100)}..."`);
      }
    } else {
      console.log('  No results found');
    }
  }
} catch (e) {
  console.log('✗ Error:', e.message);
}

// Test 4: Hybrid Search
console.log('\nTest 4: Hybrid Search');
console.log('--------------------');

try {
  const vs = getVectorStore();
  
  const query = 'TypeScript preference';
  console.log(`Query: "${query}"`);
  
  const results = await vs.hybridSearch(query, { limit: 3 });
  
  if (results.length > 0) {
    console.log(`  Found ${results.length} results:`);
    for (const r of results) {
      console.log(`  - [${r.source}] Score: ${r.score.toFixed(3)} (v: ${r.vectorScore?.toFixed(3)}, k: ${r.keywordScore?.toFixed(3)})`);
    }
  }
} catch (e) {
  console.log('✗ Error:', e.message);
}

// Test 5: Keyword Search (Fallback)
console.log('\nTest 5: Keyword Search');
console.log('---------------------');

try {
  const vs = getVectorStore();
  
  const query = 'SQLite';
  console.log(`Query: "${query}"`);
  
  const results = vs.keywordSearch(query, { limit: 3 });
  
  if (results.length > 0) {
    console.log(`  Found ${results.length} results:`);
    for (const r of results) {
      console.log(`  - [${r.source}] Score: ${r.score.toFixed(3)}`);
    }
  }
} catch (e) {
  console.log('✗ Error:', e.message);
}

// Test 6: Status Check
console.log('\nTest 6: Status Check');
console.log('-------------------');

try {
  const vs = getVectorStore();
  const status = vs.getStatus();
  
  console.log('Vector Store Status:');
  console.log(`  Initialized: ${status.initialized}`);
  console.log(`  Model: ${status.model}`);
  console.log(`  Dimensions: ${status.dimensions}`);
  console.log(`  Total Chunks: ${status.totalChunks}`);
  console.log(`  Last Indexed: ${status.lastIndexed}`);
  console.log(`  DB Path: ${status.dbPath}`);
} catch (e) {
  console.log('✗ Error:', e.message);
}

// Cleanup
console.log('\n========================================');
console.log('Tests Complete');
console.log('========================================');

// Close connection
const vs = getVectorStore();
vs.close();
EOF

# Run tests
RUN node test-vector-search.mjs

# Verify results
RUN echo "\nVerifying installation..." && \
    ls -la /root/.opencode/memory/ && \
    ls -la /root/.opencode/memory/vector-index.db || echo "Vector DB created"

CMD ["node", "test-vector-search.mjs"]