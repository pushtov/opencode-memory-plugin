# Simplified Dockerfile for OpenCode Memory Plugin Testing
FROM node:20-bullseye-slim

# Set environment variables
ENV NODE_ENV=testing
ENV DEBIAN_FRONTEND=noninteractive

# Set working directory
WORKDIR /usr/src/app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    bash \
    && rm -rf /var/lib/apt/lists/*

# Install the plugin from npm registry (faster than building from source)
RUN npm install -g @csuwl/opencode-memory-plugin@1.1.0

# Verify installation
RUN echo "=== Verifying Plugin Installation ===" && \
    ls -la ~/.opencode/memory/ && \
    echo "" && \
    echo "=== Configuration File ===" && \
    cat ~/.opencode/memory/memory-config.json && \
    echo "" && \
    echo "=== Memory Files ===" && \
    ls -la ~/.opencode/memory/*.md 2>/dev/null | wc -l && \
    echo "memory files found"

# Copy test scripts (for reference, not used in this simplified version)
COPY test-docker.sh /usr/src/app/test-docker.sh
COPY test-opencode-integration.sh /usr/src/app/test-opencode-integration.sh

# Make test scripts executable
RUN chmod +x /usr/src/app/test-docker.sh && \
    chmod +x /usr/src/app/test-opencode-integration.sh

# Copy plugin source for reference
COPY opencode-memory-plugin /usr/src/app/opencode-memory-plugin

# Create a simple test script
RUN echo '#!/bin/bash\n\
echo "========================================="\n\
echo "  OpenCode Memory Plugin v1.1.0 - Docker Test"\n\
echo "========================================="\n\
echo ""\n\
echo "Test 1: Check Node.js and npm"\n\
echo "  Node.js: $(node --version)"\n\
echo "  npm: $(npm --version)"\n\
echo ""\n\
echo "Test 2: Check plugin installation"\n\
if [ -d "$HOME/.opencode/memory" ]; then\n\
    echo "  ✓ Memory directory exists"\n\
    ls -la $HOME/.opencode/memory/\n\
else\n\
    echo "  ✗ Memory directory not found"\n\
    exit 1\n\
fi\n\
echo ""\n\
echo "Test 3: Check configuration"\n\
if [ -f "$HOME/.opencode/memory/memory-config.json" ]; then\n\
    echo "  ✓ Config file exists"\n\
    cat $HOME/.opencode/memory/memory-config.json\n\
else\n\
    echo "  ✗ Config file not found"\n\
    exit 1\n\
fi\n\
echo ""\n\
echo "Test 4: Check memory files"\n\
MEMORY_COUNT=$(ls $HOME/.opencode/memory/*.md 2>/dev/null | wc -l)\n\
echo "  Found $MEMORY_COUNT memory files"\n\
if [ "$MEMORY_COUNT" -ge 9 ]; then\n\
    echo "  ✓ All 9 core memory files present"\n\
else\n\
    echo "  ⚠ Expected 9 files, found $MEMORY_COUNT"\n\
fi\n\
echo ""\n\
echo "========================================="\n\
echo "  ✅ Docker Test Complete!"\n\
echo "========================================="\n\
' > /usr/src/app/run-tests.sh && chmod +x /usr/src/app/run-tests.sh

# Default command - run tests
CMD ["/bin/bash", "/usr/src/app/run-tests.sh"]
