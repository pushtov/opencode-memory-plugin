# Complete Dockerfile for OpenCode + Memory Plugin Testing
# Tests the plugin in the actual opencode environment

FROM node:20-bullseye-slim

ENV NODE_ENV=production
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 make g++ curl git bash \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /root

# Install opencode-ai globally
RUN npm install -g opencode-ai@latest

# Verify opencode installation
RUN opencode --version && \
    echo "✓ opencode installed: $(opencode --version)"

# Install memory plugin
COPY opencode-memory-plugin /usr/src/app/opencode-memory-plugin
WORKDIR /usr/src/app/opencode-memory-plugin

# Install dependencies with correct platform binaries
RUN npm install --production=false --ignore-scripts
RUN npm rebuild
RUN npm install -g .

# Verify plugin installation
RUN echo "=== Memory Plugin Installation ===" && \
    ls -la ~/.opencode/memory/ && \
    echo "" && \
    cat ~/.opencode/memory/memory-config.json | head -30

# Configure opencode to use memory plugin
RUN mkdir -p ~/.config/opencode && \
    echo 'Configuring opencode with memory plugin...' && \
    cat > ~/.config/opencode/opencode.json <<'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "plugin": [
    "oh-my-opencode"
  ],
  "instructions": [
    "~/.opencode/memory/SOUL.md",
    "~/.opencode/memory/AGENTS.md",
    "~/.opencode/memory/USER.md",
    "~/.opencode/memory/IDENTITY.md",
    "~/.opencode/memory/TOOLS.md",
    "~/.opencode/memory/MEMORY.md"
  ],
  "agent": {
    "memory-automation": {
      "description": "Automatically saves important information to memory",
      "mode": "subagent",
      "tools": {
        "memory_write": true,
        "memory_read": true,
        "memory_search": true,
        "vector_memory_search": true
      },
      "permission": {
        "memory_write": "allow",
        "memory_read": "allow",
        "memory_search": "allow",
        "vector_memory_search": "allow"
      }
    },
    "memory-consolidate": {
      "description": "Consolidates daily logs into long-term memory",
      "mode": "subagent",
      "tools": {
        "memory_write": true,
        "memory_read": true,
        "memory_search": true,
        "vector_memory_search": true,
        "list_daily": true,
        "rebuild_index": true
      },
      "permission": {
        "memory_write": "allow",
        "memory_read": "allow",
        "memory_search": "allow",
        "vector_memory_search": "allow",
        "list_daily": "allow",
        "rebuild_index": "allow"
      }
    }
  },
  "tools": {
    "memory_write": true,
    "memory_read": true,
    "memory_search": true,
    "vector_memory_search": true,
    "list_daily": true,
    "init_daily": true,
    "rebuild_index": true,
    "index_status": true
  }
}
EOF

RUN echo "✓ opencode configured" && \
    echo "" && \
    echo "=== opencode Configuration ===" && \
    cat ~/.config/opencode/opencode.json

# Create comprehensive test scenarios
COPY <<'EOF' /root/test-scenarios.txt
===========================================
OpenCode Memory Plugin - Test Scenarios
===========================================

SCENARIO 1: Development Workflow
User: "I'm building a React app with TypeScript"
Task: Save this preference to memory

SCENARIO 2: Bug Investigation
User: "Investigate the sharp module compatibility issue"
Task: Search for related information, save findings

SCENARIO 3: Technical Decision
User: "We decided to use hybrid search with 70/30 weights"
Task: Document this decision with reasoning

SCENARIO 4: Project Context
User: "This is the OpenCode Memory Plugin v1.1.0"
Task: Save project information and architecture

SCENARIO 5: Meeting Notes
User: "Discussed performance optimization strategies"
Task: Save meeting notes with action items

SCENARIO 6: Code Review Feedback
User: "Prefer TypeScript interfaces over types"
Task: Save as coding standard

SCENARIO 7: Semantic Search Test
User: "How do I handle async errors in TypeScript?"
Task: Search semantically for similar solutions

SCENARIO 8: Multi-day Project
User: "Working on vector search implementation"
Task: Create daily logs across multiple days

SCENARIO 9: Configuration Testing
User: "Switch to bm25-only mode for keyword search"
Task: Test configuration changes

SCENARIO 10: Automation Test
User: "@memory-automation save important information"
Task: Test automatic memory saving
EOF

# Create test script
COPY <<'EOF' /root/run-opencode-tests.sh
#!/bin/bash

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${2}$1${NC}"; }
log_section() { echo -e "\n${BLUE}========================================${NC}"; echo -e "${BLUE}$1${NC}"; echo -e "${BLUE}========================================${NC}\n"; }

log_section "OpenCode + Memory Plugin - Complete Tests"

echo "Environment:"
echo "  OpenCode: $(opencode --version)"
echo "  Memory Plugin: Installed"
echo "  Config: ~/.config/opencode/opencode.json"
echo ""

# Verify configuration
log_section "1. Configuration Verification"

if [ -f ~/.config/opencode/opencode.json ]; then
    log "✓ opencode config exists"
    echo ""
    echo "Tools configured:"
    grep -A 10 '"tools"' ~/.config/opencode/opencode.json | grep 'true' | wc -l | xargs echo "  - Count:"
    echo ""
    echo "Agents configured:"
    grep '"agent"' ~/.config/opencode/opencode.json | grep -o '"[^"]*-automation[^"]*"' | sed 's/"//g' | sed 's/^/  - /'
else
    log "✗ Config not found" "$RED"
    exit 1
fi

# Test 2: Memory Write via OpenCode
log_section "2. Memory Write - Using OpenCode"

echo "Test: Write project information"
echo ""

# Use opencode run to execute memory_write
opencode run "
Use the memory_write tool to save the following information:
- Type: project-info
- Content: 'OpenCode Memory Plugin v1.1.0 - Complete persistent memory system with vector search, 5 embedding models, and 4 search modes. Located at ~/.opencode/memory/'
- Tags: ['project', 'plugin', 'v1.1.0', 'memory']
" 2>&1 | tee /root/test1-write.log

echo ""
log "✓ Test 1 completed - check log above" "$GREEN"

# Test 3: Memory Read
log_section "3. Memory Read - Using OpenCode"

echo "Test: Read back the saved information"
echo ""

opencode run "
Use the memory_read tool to read the MEMORY.md file and show me what was saved.
" 2>&1 | tee /root/test2-read.log

echo ""
log "✓ Test 2 completed" "$GREEN"

# Test 4: Memory Search
log_section "4. Memory Search - Using OpenCode"

echo "Test: Search for project information"
echo ""

opencode run "
Use the memory_search tool to search for 'project plugin v1.1.0' and show the results.
" 2>&1 | tee /root/test3-search.log

echo ""
log "✓ Test 3 completed" "$GREEN"

# Test 5: Check Daily Logs
log_section "5. Daily Log Operations"

echo "Test: List and check daily logs"
echo ""

opencode run "
Use the list_daily tool to show available daily logs for the past 7 days.
" 2>&1 | tee /root/test4-daily.log

echo ""
log "✓ Test 4 completed" "$GREEN"

# Test 6: Index Status
log_section "6. Vector Index Status"

echo "Test: Check vector search index"
echo ""

opencode run "
Use the index_status tool to check the status of the vector search index.
" 2>&1 | tee /root/test5-index.log

echo ""
log "✓ Test 5 completed" "$GREEN"

# Test 7: Configuration Check
log_section "7. Configuration Verification"

echo "Test: Read memory configuration"
echo ""

opencode run "
Read the file at ~/.opencode/memory/memory-config.json and summarize the configuration, including:
- Search mode
- Embedding model
- Available models
- Fallback mode
" 2>&1 | tee /root/test6-config.log

echo ""
log "✓ Test 6 completed" "$GREEN"

# Test 8: Agent Test
log_section "8. Memory Automation Agent"

echo "Test: Test memory-automation agent"
echo ""

opencode run "
Run the @memory-automation agent with the following request:
'Save this information to memory: User prefers to use TypeScript for all new projects. Always enable strict type checking and use interfaces for object definitions.'
" 2>&1 | tee /root/test7-agent.log

echo ""
log "✓ Test 7 completed" "$GREEN"

# Final Summary
log_section "Test Summary"

echo "Test logs saved to:"
echo "  - /root/test1-write.log (memory write)"
echo "  - /root/test2-read.log (memory read)"
echo "  - /root/test3-search.log (search)"
echo "  - /root/test4-daily.log (daily logs)"
echo "  - /root/test5-index.log (index status)"
echo "  - /root/test6-config.log (configuration)"
echo "  - /root/test7-agent.log (automation)"
echo ""

echo "========================================="
echo "  ✅ ALL OPENCODE TESTS COMPLETED!"
echo "========================================="
echo ""

# Show memory directory
echo "Memory Directory Contents:"
ls -la ~/.opencode/memory/
echo ""

echo "Core Memory Files:"
ls -1 ~/.opencode/memory/*.md | wc -l | xargs echo "  Files:"
ls -1 ~/.opencode/memory/*.md | head -5 | sed 's|^.*/|  - |'
echo ""

echo "Configuration:"
cat ~/.opencode/memory/memory-config.json | jq '.search.mode, .embedding.model' 2>/dev/null || cat ~/.opencode/memory/memory-config.json | head -10

echo ""
echo "🎉 OpenCode Memory Plugin is FULLY FUNCTIONAL!"
echo ""

CMD ["/bin/bash", "/root/run-opencode-tests.sh"]
EOF

RUN chmod +x /root/run-opencode-tests.sh

# Set working directory for opencode
WORKDIR /root/test-project
RUN mkdir -p /root/test-project

# Default command
CMD ["/bin/bash", "/root/run-opencode-tests.sh"]
